<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Simulantara.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:Simulantara.Views"
    Shell.FlyoutBehavior="Disabled">

    <!-- Dashboard -->
    <ShellContent
        Title="Dashboard"
        ContentTemplate="{DataTemplate views:DashboardPage}"
        Route="DashboardPage" />

    <!-- Habit -->
    <ShellContent
        Title="Habits"
        ContentTemplate="{DataTemplate views:HabitManagePage}"
        Route="HabitManagePage" />

    <!-- Profile -->
    <ShellContent
        Title="Profile"
        ContentTemplate="{DataTemplate views:ProfilePage}"
        Route="ProfilePage" />

</Shell>