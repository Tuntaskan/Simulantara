<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Simulantara.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:Simulantara.Views"
    Shell.FlyoutBehavior="Disabled"
    Title="Simulantara">

    <ShellContent
        Title="Home"
        ContentTemplate="{DataTemplate views:MainPage}"
        Route="MainPage" />

    <TabBar>
        <ShellContent Title="Home" ContentTemplate="{DataTemplate views:MainPage}" />
        <ShellContent Title="Habit" ContentTemplate="{DataTemplate views:HabitPage}" />
        <ShellContent Title="NPC" ContentTemplate="{DataTemplate views:NPCPage}" />
    </TabBar>
</Shell>