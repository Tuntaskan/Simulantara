<?xml version="1.0" encoding="utf-8" ?>

<ContentPage
    x:Class="Simulantara.Views.BackgroundCustomPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:model="clr-namespace:Simulantara.Models"
    x:Name="ThisPage"
    Title="Background Custom"
    NavigationPage.HasNavigationBar="False"
    BackgroundColor="Black">

    <Grid>

        <!-- DEFAULT BACKGROUND -->
        <Image
            Source="{Binding SelectedBackground.Image}"
            Aspect="AspectFill" />

        <!-- OVERLAY -->
        <BoxView Color="#66000000" />

        <!-- ================= MAIN LAYOUT ================= -->
        <Grid RowDefinitions="Auto,*,95">

            <!-- ================= HEADER ================= -->
            <Grid
                Padding="25,55,25,15"
                ColumnDefinitions="*">

                <VerticalStackLayout Spacing="4">

                    <Label
                        Text="Background Custom"
                        FontSize="32"
                        FontAttributes="Bold"
                        TextColor="White" />

                    <Label
                        Text="Choose your world"
                        FontSize="15"
                        TextColor="#E0E0E0" />

                </VerticalStackLayout>

            </Grid>

            <!-- ================= CONTENT ================= -->
            <ScrollView Grid.Row="1">

                <VerticalStackLayout
                    Padding="20,10,20,20"
                    Spacing="20">

                    <!-- ================= USER LEVEL ================= -->
                    <Frame
                        Padding="15"
                        BackgroundColor="#1E1E1E"
                        CornerRadius="20"
                        BorderColor="#404040"
                        HasShadow="False">

                        <Grid ColumnDefinitions="*,90">

                            <VerticalStackLayout Spacing="12">

                                <Label
                                    Text="Level Progress"
                                    FontSize="20"
                                    FontAttributes="Bold"
                                    TextColor="White" />

                                <!-- LEVEL -->
                                <HorizontalStackLayout Spacing="10">

                                    <Label
                                        Text="Level"
                                        FontAttributes="Bold"
                                        TextColor="White" />

                                    <Label
                                        Text="{Binding User.Level}"
                                        TextColor="#FFD700"
                                        FontAttributes="Bold" />

                                </HorizontalStackLayout>

                                <!-- EXP -->
                                <HorizontalStackLayout Spacing="10">

                                    <Label
                                        Text="EXP"
                                        FontAttributes="Bold"
                                        TextColor="White" />

                                    <Label
                                        Text="{Binding User.Exp}"
                                        TextColor="#00FFAA"
                                        FontAttributes="Bold" />

                                    <Label
                                        Text="/100"
                                        TextColor="White" />

                                </HorizontalStackLayout>

                                <!-- PROGRESS -->
                                <Grid>

                                    <ProgressBar
                                        HeightRequest="18"
                                        ScaleY="1.5"
                                        Progress="{Binding User.Exp, Converter={StaticResource ExpToProgressConverter}}"
                                        ProgressColor="#7ED957"
                                        BackgroundColor="#444444" />

                                    <Label
                                        HorizontalOptions="Center"
                                        VerticalOptions="Center"
                                        FontSize="12"
                                        FontAttributes="Bold"
                                        TextColor="Black">

                                        <Label.FormattedText>

                                            <FormattedString>
                                                <Span Text="{Binding User.Exp}" />
                                                <Span Text="/100 EXP" />
                                            </FormattedString>

                                        </Label.FormattedText>

                                    </Label>

                                </Grid>

                            </VerticalStackLayout>

                            <!-- PROFILE -->
                            <Frame
                                Grid.Column="1"
                                Padding="0"
                                HeightRequest="80"
                                WidthRequest="80"
                                CornerRadius="40"
                                BorderColor="White"
                                BackgroundColor="#DDDDDD"
                                HorizontalOptions="End"
                                HasShadow="False">

                                <Image
                                    Aspect="AspectFill"
                                    Source="{Binding User.ProfileImage}" />

                            </Frame>

                        </Grid>

                    </Frame>

                    <!-- ================= CURRENT BACKGROUND ================= -->
                    <VerticalStackLayout
                        HorizontalOptions="Center"
                        Spacing="12">

                        <Label
                            Text="Current Background"
                            FontSize="22"
                            FontAttributes="Bold"
                            TextColor="White" />

                        <Frame
                            Padding="0"
                            HeightRequest="180"
                            WidthRequest="320"
                            CornerRadius="28"
                            BackgroundColor="#55FFFFFF"
                            HasShadow="False"
                            IsClippedToBounds="True">

                            <Image
                                Source="{Binding SelectedBackground.Image}"
                                Aspect="AspectFill" />

                        </Frame>

                        <Label
                            Text="{Binding SelectedBackground.Name}"
                            FontSize="18"
                            FontAttributes="Bold"
                            TextColor="White"
                            HorizontalOptions="Center" />

                    </VerticalStackLayout>

                    <!-- ================= BACKGROUND LIST ================= -->
                    <Frame
                        Padding="20"
                        BackgroundColor="#4A6FFF"
                        CornerRadius="25"
                        HasShadow="False">

                        <VerticalStackLayout Spacing="18">

                            <!-- TITLE -->
                            <Label
                                Text="Background List"
                                FontSize="20"
                                FontAttributes="Bold"
                                TextColor="White" />

                            <CollectionView
                                HeightRequest="500"
                                ItemsSource="{Binding Backgrounds}"
                                SelectionMode="None">

                                <CollectionView.ItemsLayout>

                                    <GridItemsLayout
                                        Orientation="Vertical"
                                        Span="2"
                                        HorizontalItemSpacing="15"
                                        VerticalItemSpacing="18" />

                                </CollectionView.ItemsLayout>

                                <CollectionView.ItemTemplate>

                                    <DataTemplate>

                                        <VerticalStackLayout
                                            HorizontalOptions="Center"
                                            Spacing="8">

                                            <!-- CARD -->
                                            <Frame
                                                Padding="8"
                                                CornerRadius="20"
                                                HasShadow="False"
                                                BackgroundColor="#FFFFFF">

                                                <VerticalStackLayout
                                                    Spacing="8"
                                                    HorizontalOptions="Center">

                                                    <!-- BACKGROUND BUTTON -->
                                                    <ImageButton
    HeightRequest="100"
    WidthRequest="140"
    BackgroundColor="Transparent"
    Aspect="AspectFill"
    Source="{Binding Image}"
    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SelectBackgroundCommand}"
    CommandParameter="{Binding .}">

                                                        <ImageButton.Opacity>
                                                            <MultiBinding Converter="{StaticResource LevelOpacityConverter}">

                                                                <!-- UnlockLevel -->
                                                                <Binding Path="UnlockLevel" />

                                                                <!-- User Level -->
                                                                <Binding
                Source="{x:Reference ThisPage}"
                Path="BindingContext.User.Level" />

                                                            </MultiBinding>
                                                        </ImageButton.Opacity>

                                                    </ImageButton>
                                                    <!-- NAME -->
                                                    <Label
                                                        Text="{Binding Name}"
                                                        FontSize="14"
                                                        FontAttributes="Bold"
                                                        HorizontalTextAlignment="Center"
                                                        TextColor="Black"
                                                        Opacity="{Binding UnlockLevel, Converter={StaticResource LevelOpacityConverter}}" />

                                                    <!-- LEVEL REQUIREMENT -->
                                                    <Label
                                    FontSize="11"
                                    HorizontalTextAlignment="Center">

                                                        <Label.FormattedText>

                                                            <FormattedString>

                                                                <Span
                                                Text="Unlock Lv "
                                                TextColor="#666666" />

                                                                <Span
                                                Text="{Binding UnlockLevel}"
                                                TextColor="#4A6FFF"
                                                FontAttributes="Bold" />

                                                            </FormattedString>

                                                        </Label.FormattedText>

                                                    </Label>

                                                </VerticalStackLayout>

                                            </Frame>

                                        </VerticalStackLayout>

                                    </DataTemplate>

                                </CollectionView.ItemTemplate>

                            </CollectionView>

                        </VerticalStackLayout>

                    </Frame>

                </VerticalStackLayout>

            </ScrollView>

            <!-- ================= BOTTOM NAV ================= -->
            <Grid
                Grid.Row="2"
                ColumnDefinitions="*,*,*,*"
                BackgroundColor="#6A4B3C"
                Padding="10">

                <!-- HOME -->
                <Frame
                    Grid.Column="0"
                    HeightRequest="50"
                    WidthRequest="50"
                    Padding="0"
                    CornerRadius="12"
                    BackgroundColor="#D9E0E3"
                    HasShadow="False"
                    HorizontalOptions="Center"
                    VerticalOptions="Center">

                    <ImageButton
                        Source="home.png"
                        BackgroundColor="Transparent"
                        Clicked="OnHomeClicked" />

                </Frame>

                <!-- HABIT -->
                <Frame
                    Grid.Column="1"
                    HeightRequest="50"
                    WidthRequest="50"
                    Padding="0"
                    CornerRadius="12"
                    BackgroundColor="#D9E0E3"
                    HasShadow="False"
                    HorizontalOptions="Center"
                    VerticalOptions="Center">

                    <ImageButton
                        Source="addhabit.png"
                        BackgroundColor="Transparent"
                        Clicked="OnHabitClicked" />

                </Frame>

                <!-- NPC -->
                <Frame
                    Grid.Column="2"
                    HeightRequest="50"
                    WidthRequest="50"
                    Padding="0"
                    CornerRadius="12"
                    BackgroundColor="#D9E0E3"
                    HasShadow="False"
                    HorizontalOptions="Center"
                    VerticalOptions="Center">

                    <ImageButton
                        Source="npc.png"
                        BackgroundColor="Transparent"
                        Clicked="OnNpcClicked" />

                </Frame>

                <!-- BACKGROUND -->
                <Frame
                    Grid.Column="3"
                    HeightRequest="50"
                    WidthRequest="50"
                    Padding="0"
                    CornerRadius="12"
                    BackgroundColor="#FF3B5F"
                    HasShadow="False"
                    HorizontalOptions="Center"
                    VerticalOptions="Center">

                    <ImageButton
                        Source="backgroundicon.png"
                        BackgroundColor="Transparent" />

                </Frame>

            </Grid>

        </Grid>

    </Grid>

</ContentPage>