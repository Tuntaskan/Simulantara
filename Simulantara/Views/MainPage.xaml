<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Simulantara.Views.MainPage"
             Title="MainPage">

    <StackLayout Padding="20">
        <Label Text="Simulantara" FontSize="30"/>

        <Label Text="Level:"/>
        <Label Text="{Binding Level}" FontSize="24"/>

        <Label Text="EXP:"/>
        <Label Text="{Binding Exp}" />

        <ProgressBar Progress="{Binding Exp}" />
    </StackLayout>

</ContentPage>