<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Simulantara.Views.HabitManagePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewmodels="clr-namespace:Simulantara.ViewModels"
    xmlns:models="clr-namespace:Simulantara.Models"
    x:DataType="viewmodels:HabitManageViewModel"
    x:Name="ThisPage"
    NavigationPage.HasNavigationBar="False"
    BackgroundColor="Black">

    <Grid>

        <!-- BACKGROUND -->
        <Image
            Source="{Binding CurrentBackground.Image}"
            Aspect="AspectFill" />

        <!-- OVERLAY -->
        <BoxView Color="#66000000" Opacity="0.4" />

        <!-- MAIN -->
        <Grid RowDefinitions="Auto,*,95">

            <!-- ================= HEADER ================= -->
            <Grid
                Padding="25,55,25,15"
                ColumnDefinitions="*,Auto">

                <VerticalStackLayout
                    Spacing="4">

                    <Label
                        Text="Habit Manager"
                        FontSize="32"
                        FontAttributes="Bold"
                        TextColor="White" />

                    <Label
                        Text="Kelola semua habit kamu"
                        FontSize="15"
                        TextColor="#E0E0E0" />

                </VerticalStackLayout>

                <!-- ADD BUTTON -->
                <Frame
                    Grid.Column="1"
                    HeightRequest="55"
                    WidthRequest="55"
                    Padding="0"
                    CornerRadius="18"
                    BackgroundColor="#FF3B5F"
                    HasShadow="False"
                    VerticalOptions="Center">

                    <ImageButton
                        Source="addhabit.png"
                        BackgroundColor="Transparent"
                        Command="{Binding AddHabitCommand}" />

                </Frame>

            </Grid>

            <!-- ================= CONTENT ================= -->
            <Grid Grid.Row="1">

                <!-- EMPTY STATE -->
                <VerticalStackLayout
                    IsVisible="{Binding Habits.Count, Converter={StaticResource ZeroToBoolConverter}}"
                    HorizontalOptions="Center"
                    VerticalOptions="Center"
                    Spacing="15">

                    <Image
                        Source="habit_empty.png"
                        HeightRequest="140"
                        WidthRequest="140"
                        Opacity="0.9" />

                    <Label
                        Text="Belum ada habit"
                        FontSize="22"
                        FontAttributes="Bold"
                        TextColor="White"
                        HorizontalTextAlignment="Center" />

                    <Label
                        Text="Tekan tombol + untuk membuat habit baru"
                        FontSize="15"
                        TextColor="#D9D9D9"
                        HorizontalTextAlignment="Center" />

                </VerticalStackLayout>

                <!-- HABIT LIST -->
                <CollectionView
                    ItemsSource="{Binding Habits}"
                    Margin="20,0,20,10"
                    SelectionMode="None">

                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout
                            Orientation="Vertical"
                            ItemSpacing="15" />
                    </CollectionView.ItemsLayout>

                    <CollectionView.ItemTemplate>

                        <DataTemplate x:DataType="models:Habit">

                            <Frame
                                Padding="18"
                                CornerRadius="25"
                                BackgroundColor="#CC1E1E1E"
                                BorderColor="#33FFFFFF"
                                HasShadow="False">

                                <Grid
                                    ColumnDefinitions="*,Auto"
                                    RowDefinitions="Auto,Auto,Auto">

                                    <!-- HABIT NAME -->
                                    <Label
                                        Text="{Binding Name}"
                                        FontSize="22"
                                        FontAttributes="Bold"
                                        TextColor="White" />

                                    <!-- DELETE BUTTON -->
                                    <Frame
                                        Grid.Column="1"
                                        HeightRequest="42"
                                        WidthRequest="42"
                                        Padding="0"
                                        CornerRadius="12"
                                        BackgroundColor="#FF4A4A"
                                        HasShadow="False">

                                        <ImageButton
                                            Source="delete.png"
                                            BackgroundColor="Transparent"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:HabitManageViewModel}}, Path=DeleteHabitCommand}"
                                            CommandParameter="{Binding .}" />

                                    </Frame>

                                    <!-- DESCRIPTION -->
                                    <Label
                                        Grid.Row="1"
                                        Grid.ColumnSpan="2"
                                        Margin="0,10,0,0"
                                        Text="{Binding Description}"
                                        FontSize="14"
                                        TextColor="#D6D6D6"
                                        LineBreakMode="WordWrap" />

                                    <!-- BOTTOM INFO -->
                                    <Grid
                                        Grid.Row="2"
                                        Grid.ColumnSpan="2"
                                        Margin="0,18,0,0"
                                        ColumnDefinitions="*,Auto,Auto"
                                        ColumnSpacing="10">

                                        <!-- CATEGORY -->
                                        <Frame
                                            Grid.Column="0"
                                            Padding="14,8"
                                            CornerRadius="14"
                                            BackgroundColor="#FF3B5F"
                                            HasShadow="False"
                                            HorizontalOptions="Start"
                                            MaximumWidthRequest="180">

                                            <Label
                                                Text="{Binding Category.Name}"
                                                FontSize="13"
                                                FontAttributes="Bold"
                                                TextColor="White"
                                                LineBreakMode="WordWrap"
                                                MaxLines="2" />

                                        </Frame>

                                        <!-- DETAIL BUTTON -->
                                        <Frame
                                            Grid.Column="1"
                                            HeightRequest="42"
                                            WidthRequest="42"
                                            Padding="0"
                                            CornerRadius="12"
                                            BackgroundColor="#5C7CFA"
                                            HasShadow="False"
                                            VerticalOptions="Center">

                                            <Button
                                                Text="Detail"
                                                BackgroundColor="Transparent"
                                                Command="{Binding BindingContext.OpenHabitDetailCommand, Source={x:Reference ThisPage}}"
                                                CommandParameter="{Binding .}" />

                                        </Frame>

                                        <!-- STREAK -->
                                        <HorizontalStackLayout
                                            Grid.Column="2"
                                            Spacing="6"
                                            VerticalOptions="Center">

                                            <Image
                                                Source="fire.png"
                                                HeightRequest="18"
                                                WidthRequest="18" />

                                            <Label
                                                Text="{Binding Streak}"
                                                FontSize="16"
                                                FontAttributes="Bold"
                                                TextColor="#FFD166" />

                                        </HorizontalStackLayout>

                                    </Grid>

                                </Grid>

                            </Frame>

                        </DataTemplate>

                    </CollectionView.ItemTemplate>

                </CollectionView>

            </Grid>

            <!-- ================= BOTTOM NAVBAR ================= -->
            <Grid
                Grid.Row="2"
                ColumnDefinitions="*,*,*,*"
                BackgroundColor="#6A4B3C"
                Padding="10">

                <!-- HOME -->
                <Frame
                    Grid.Column="0"
                    HeightRequest="50"
                    WidthRequest="50"
                    Padding="0"
                    CornerRadius="12"
                    BackgroundColor="#D9E0E3"
                    HasShadow="False"
                    HorizontalOptions="Center"
                    VerticalOptions="Center">

                    <ImageButton
                        Source="home.png"
                        BackgroundColor="Transparent" 
                        Command="{Binding OpenDashboardCommand}" />

                </Frame>

                <!-- HABIT -->
                <Frame
                    Grid.Column="1"
                    HeightRequest="50"
                    WidthRequest="50"
                    Padding="0"
                    CornerRadius="12"
                    BackgroundColor="#FF3B5F"
                    HasShadow="False"
                    HorizontalOptions="Center"
                    VerticalOptions="Center">

                    <ImageButton
                        Source="addhabit.png"
                        BackgroundColor="Transparent"
                        Command="{Binding AddHabitCommand}" />

                </Frame>

                <!-- NPC -->
                <Frame
                    Grid.Column="2"
                    HeightRequest="50"
                    WidthRequest="50"
                    Padding="0"
                    CornerRadius="12"
                    BackgroundColor="#D9E0E3"
                    HasShadow="False"
                    HorizontalOptions="Center"
                    VerticalOptions="Center">

                    <ImageButton
                        Source="npc.png"
                        BackgroundColor="Transparent" 
                        Command="{Binding OpenNpcCustomCommand}" />

                </Frame>

                <!-- BACKGROUND -->
                <Frame
                    Grid.Column="3"
                    HeightRequest="50"
                    WidthRequest="50"
                    Padding="0"
                    CornerRadius="12"
                    BackgroundColor="#D9E0E3"
                    HasShadow="False"
                    HorizontalOptions="Center"
                    VerticalOptions="Center">

                    <ImageButton
                        Source="backgroundicon.png"
                        BackgroundColor="Transparent" />

                </Frame>

            </Grid>

        </Grid>

    </Grid>

</ContentPage>